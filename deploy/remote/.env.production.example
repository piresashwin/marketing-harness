# Production secrets for inflxr.com — lives at /opt/inflxr/.env.production ON THE
# DROPLET. NEVER committed, NEVER rsynced (deploy.sh excludes it). Copy this to
# .env.production on the droplet and fill in real values, then run bootstrap.sh.
# deploy.sh refuses to deploy if a required key is empty or a CHANGE_ME remains.
# PORT is set by the image — don't put it here.

# ── Public origin ─────────────────────────────────────────────────────────────
# Instagram fetches the OAuth redirect + media over the public internet, so this
# MUST be the real https origin (CLAUDE.md §5). The SPA is served same-origin in
# prod, so APP_BASE_URL is the same value.
PUBLIC_BASE_URL=https://inflxr.com
APP_BASE_URL=https://inflxr.com

# ── Database (separate `inflxr` DB + role inside the shared tradex-postgres) ────
# Host is the CONTAINER NAME tradex-postgres, reachable over the edge net. The
# password here is the single source of truth — bootstrap.sh parses it to
# provision the role, so they can never drift. Pick a strong one.
DATABASE_URL=postgresql://inflxr:CHANGE_ME@tradex-postgres:5432/inflxr

# ── Encryption at rest (AES-256-GCM) ────────────────────────────────────────────
# 32-byte key, hex-encoded (64 hex chars):  openssl rand -hex 32
APP_ENCRYPTION_KEY=CHANGE_ME

# ── Magic-link email (Resend) ───────────────────────────────────────────────────
# Verify a domain in Resend and set RESEND_FROM to a sender on it to deliver to
# arbitrary recipients (the shared onboarding@resend.dev only mails your own acct).
RESEND_API_KEY=CHANGE_ME
RESEND_FROM=inflxr <noreply@inflxr.com>

# ── Instagram connector (central Meta app you own) ──────────────────────────────
IG_CLIENT_ID=CHANGE_ME
IG_CLIENT_SECRET=CHANGE_ME
# Must be listed verbatim in the Meta app's OAuth redirect URIs.
IG_REDIRECT_URI=https://inflxr.com/connectors/instagram/callback
IG_GRAPH_VERSION=v21.0

# ── Media store — S3 / Cloudflare R2 (PUBLIC bucket; Instagram fetches from here) ─
MEDIA_STORE=s3
# R2 example: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=CHANGE_ME
S3_REGION=auto
S3_BUCKET=inflxr-media
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_FORCE_PATH_STYLE=true
# The PUBLIC base URL objects are served from — must be internet-reachable by
# Instagram. For R2, this is the bucket's public r2.dev URL or a custom domain.
S3_PUBLIC_BASE_URL=CHANGE_ME
