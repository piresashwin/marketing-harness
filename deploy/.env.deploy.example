# Local deploy config. Copy to deploy/.env.deploy and fill in.
# Sourced by build.sh / deploy.sh / bootstrap.sh / verify.sh. Never commit the
# populated copy (deploy/.env.deploy is gitignored).

DEPLOY_USER=root
# The SHARED droplet (same host as tradex + hiredesq).
DEPLOY_HOST=68.183.100.195
DEPLOY_PATH=/opt/inflxr

# Public origin. Used to derive the host for the vhost filename, the cert, and the
# verify curls. NB: unlike the hiredesq Next.js build, NOTHING is baked into the
# SPA bundle from this — the marketing-harness SPA calls relative /api,/auth on its
# own origin, so the public URL is a pure RUNTIME value (.env.production on the
# droplet). This is here only for the deploy scripts' bookkeeping.
PUBLIC_APP_URL=https://inflxr.com

# Shared-infrastructure integration. inflxr runs no nginx and no Postgres of its
# own — the tradex stack owns both. These must match the tradex stack:
#   SHARED_NET           docker network the tradex nginx/postgres and this stack join
#   VHOST_DIR            host dir the tradex nginx mounts at conf.d/vhosts
#   PROXY_CONTAINER      tradex nginx container name (reloaded after vhost drop)
#   SHARED_PG_CONTAINER  tradex Postgres container; deploy.sh attaches it to SHARED_NET
#                        so inflxr-app can reach it (DATABASE_URL host = this name)
SHARED_NET=edge
VHOST_DIR=/srv/nginx-vhosts
PROXY_CONTAINER=tradex-nginx
SHARED_PG_CONTAINER=tradex-postgres

# Cert bootstrap (used by bootstrap.sh only). The shared certbot lives in the
# tradex stack; TRADEX_DEPLOY_PATH is where its compose + certbot service live on
# the droplet. CERT_EMAIL registers the Let's Encrypt account.
TRADEX_DEPLOY_PATH=/opt/tradex
CERT_EMAIL=admin@inflxr.com

# Post-deploy verification (verify.sh):
#   APP_MARKER              a string in inflxr's served HTML shell but NOT on a
#                           sibling's homepage. The SPA is client-rendered, so curl
#                           only sees index.html — this matches its <title>.
#   SIBLING_PROXY_DOMAINS   space-separated OTHER domains the SAME shared proxy
#                           serves. verify asserts each still serves its own app
#                           (the bleed guard). Leave empty to skip.
APP_MARKER=Marketing Harness
SIBLING_PROXY_DOMAINS="hiredesq.com tradex.inflxr.com"

# SSH options (optional). Override if you use a non-default key/port.
# SSH_OPTS="-i ~/.ssh/id_ed25519 -p 22"
