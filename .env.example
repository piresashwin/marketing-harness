# ── Harness HTTP server ───────────────────────────────────────────────
PORT=8787
# Public URL the harness is reachable at. For local IG OAuth + media fetch,
# this must be a PUBLIC https URL (use a tunnel, e.g. cloudflared/ngrok)
# because Instagram's servers fetch the redirect + media over the internet.
PUBLIC_BASE_URL=http://localhost:8787
# Where the web UI lives. Dev = Vite (5173); prod = same as PUBLIC_BASE_URL.
APP_BASE_URL=http://localhost:5173

# ── Magic-link email (Resend) ─────────────────────────────────────────
# Without a key, links are printed to the console (dev only).
RESEND_API_KEY=
RESEND_FROM=Marketing Harness <onboarding@resend.dev>

# ── Database (the Postgres instance we set up on port 5433) ───────────
DATABASE_URL=postgresql://harness:harness_dev_pw@localhost:5433/marketing_harness

# ── Instagram connector (CENTRAL Meta app — you own these) ────────────
# Create an app at https://developers.facebook.com, add the Instagram product,
# and add yourself/testers as roles while the app is in Development mode.
IG_CLIENT_ID=
IG_CLIENT_SECRET=
# Defaults to ${PUBLIC_BASE_URL}/connectors/instagram/callback if left blank.
# This exact URL must be listed in your Meta app's OAuth redirect URIs.
IG_REDIRECT_URI=
IG_GRAPH_VERSION=v21.0

# ── Media store: "s3" (recommended) or "local" ───────────────────────
MEDIA_STORE=s3

# S3-compatible (works with the local MinIO on :9000, or AWS S3 / R2 / B2)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketing-harness-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# Public base URL objects are served from (must be reachable by Instagram).
# For MinIO path-style this is ${S3_ENDPOINT}/${S3_BUCKET}.
S3_PUBLIC_BASE_URL=http://localhost:9000/marketing-harness-media

# Local file store (only used when MEDIA_STORE=local)
LOCAL_MEDIA_DIR=.media
LOCAL_MEDIA_BASE_URL=http://localhost:8787/media
