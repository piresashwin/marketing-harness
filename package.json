{
  "name": "marketing-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BYOK marketing automation harness exposed over MCP. Slice 1: Instagram publish-now.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "concurrently -n api,web -c blue,magenta \"npm:dev\" \"npm:dev --prefix web\"",
    "build": "tsc -p tsconfig.json && npm run build --prefix web",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.668.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
